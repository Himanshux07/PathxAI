PORT=4000
JWT_SECRET=change-this-secret
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=mongodb://127.0.0.1:27017/pathxai
DEMO_PATIENT_ID=PATIENT001
DEMO_PASSWORD=123456

# Pipeline Configuration
# Stage 1: Voice → Text (OpenAI Whisper)
TRANSCRIPTION_API_KEY=<your-openai-api-key>
TRANSCRIPTION_MODEL=whisper-1

# Stage 2: Text → JSON (Groq)
GROQ_API_KEY=<your-groq-api-key>
GROQ_STRUCTURED_DATA_MODEL=mixtral-8x7b-32768

# Optional
TRANSCRIPTION_LANGUAGE=auto

# Optional language hint for transcription
TRANSCRIPTION_LANGUAGE=hi

# Optional Cloudinary audio storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
